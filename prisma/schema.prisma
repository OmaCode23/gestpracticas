// prisma/schema.prisma
// Ejecutar: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id            Int      @id @default(autoincrement())
  nombre        String
  cif           String   @unique
  direccion     String?
  localidad     String
  sector        String
  cicloFormativo String?
  telefono      String?
  email         String?
  contacto      String?
  emailContacto String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  formaciones   FormacionEmpresa[]
  @@map("empresas")
}

model Alumno {
  id        Int      @id @default(autoincrement())
  nombre    String
  nia       String   @unique
  telefono  String?
  email     String?
  ciclo     String
  curso     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  formaciones FormacionEmpresa[]
  @@map("alumnos")
}

model FormacionEmpresa {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  empresa       Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  alumnoId      Int?
  alumno        Alumno?  @relation(fields: [alumnoId], references: [id])
  periodo       String?
  descripcion   String?
  contacto      String?
  curso         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("formaciones_empresa")
}
