{
  "name": "gestpracticas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "dev:next": "next dev",
    "build": "node scripts/with-db-env.mjs next build",
    "start": "node scripts/with-db-env.mjs next start",
    "start:standalone": "node scripts/with-db-env.mjs node .next/standalone/server.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:db:up": "docker compose up -d db pgbouncer",
    "docker:down": "docker compose down",
    "package:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/package-prod.ps1",
    "package:demo": "powershell -ExecutionPolicy Bypass -File ./scripts/package-demo.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "db:generate": "node scripts/with-db-env.mjs prisma generate",
    "db:migrate": "node scripts/with-db-env.mjs prisma migrate dev",
    "db:migrate:deploy": "node scripts/with-db-env.mjs prisma migrate deploy",
    "db:seed": "node scripts/with-db-env.mjs node --experimental-strip-types prisma/seed.ts",
    "db:bootstrap-admin": "node scripts/with-db-env.mjs node --experimental-strip-types prisma/bootstrap-admin.ts",
    "db:push": "node scripts/with-db-env.mjs prisma db push",
    "db:studio": "node scripts/with-db-env.mjs prisma studio"
  },
  "prisma": {
    "seed": "node scripts/with-db-env.mjs node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@prisma/client": "^5.13.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "next": "14.2.3",
    "prisma": "^5.13.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.51.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
