APP_PORT=3000

POSTGRES_DB=gestpracticas
POSTGRES_USER=gestpracticas
POSTGRES_PASSWORD=change-this-super-long-password
POSTGRES_HOST_PORT=55432

LOCAL_USE_PGBOUNCER=0
PGBOUNCER_HOST_PORT=56432
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_RESERVE_POOL_SIZE=5

PRISMA_CONNECTION_LIMIT=10
PRISMA_POOL_TIMEOUT=20

AUTH_SECRET=change-this-auth-secret
AUTH_MODE=local

# Configuracion reservada para autenticacion externa futura
EXTERNAL_AUTH_AUTHORIZE_URL=
EXTERNAL_AUTH_CLIENT_ID=
EXTERNAL_AUTH_REDIRECT_URI=
EXTERNAL_AUTH_SCOPE=openid profile email

# Solo para pruebas del callback en AUTH_MODE=external
EXTERNAL_AUTH_ALLOW_MOCK_CALLBACK=0
